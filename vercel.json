{
    "version": 2,
    "builds": [
        {
          "src": "api.py",
          "use": "@vercel/python"
        }
      ],
      "routes": [
        {
          "src": "/(.*)",
          "dest": "api.py"
        }
      ],
      "crons": [
        {
          "path": "/execute",
          "schedule": "0 10 * * *"
        },
        {
          "path": "/execute",
          "schedule": "45 22 * * *"
        }
      ]
  }