{
    "version": 2,
    "builds": [
        {
          "src": "api.py",
          "use": "@vercel/python"
        }
      ],
      "routes": [
        {
          "src": "/(.*)",
          "dest": "api.py"
        }
      ],
    "crons": [
      {
        "path": "/execute",
        "schedule": "0 16 * * *"
      },
      {
        "path": "/execute",
        "schedule": "25 11 * * *"
      }
    ]
  }