{
    "version": 2,
    "builds": [
      {
        "src": "build_files.sh",
        "use": "@vercel/python",
        "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
      }
    ],
    "crons": [
      {
        "path": "/main.py",
        "schedule": "0 16 * * *"
      },
      {
        "path": "/main.py",
        "schedule": "17 11 * * *"
      }
    ]
  }